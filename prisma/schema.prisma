datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @db.VarChar(50)
  name           String          @db.VarChar(100)
  email          String          @unique @db.VarChar(255)
  passwordHash   String          @map("password_hash") @db.VarChar(255)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp()
  projects       Project[]
  timeEntries    TimeEntry[]
  invoices       Invoice[]
  paypalSettings PaypalSettings?

  @@map("users")
}

model Project {
  id          String      @id @db.VarChar(50)
  userId      String      @map("user_id") @db.VarChar(50)
  name        String      @db.VarChar(100)
  clientName  String      @map("client_name") @db.VarChar(100)
  color       String      @db.VarChar(50)
  hourlyRate  Decimal     @default(0.00) @map("hourly_rate") @db.Decimal(10, 2)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  timeEntries TimeEntry[]
  invoices    Invoice[]

  @@map("projects")
}

model Task {
  id        String      @id @db.VarChar(50)
  projectId String      @map("project_id") @db.VarChar(50)
  name      String      @db.VarChar(100)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@map("tasks")
}

model TimeEntry {
  id                 String    @id @db.VarChar(50)
  userId             String    @map("user_id") @db.VarChar(50)
  description        String    @db.Text
  projectId          String    @map("project_id") @db.VarChar(50)
  taskId             String?   @map("task_id") @db.VarChar(50)
  startTime          DateTime  @map("start_time") @db.Timestamp()
  endTime            DateTime? @map("end_time") @db.Timestamp()
  duration           Int       @default(0)
  isBillable         Boolean   @default(true) @map("is_billable")
  isInvoiceGenerated Boolean   @default(false) @map("is_invoice_generated")
  invoiceId          String?   @map("invoice_id") @db.VarChar(50)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task               Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  invoice            Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model Invoice {
  id            String      @id @db.VarChar(50)
  userId        String      @map("user_id") @db.VarChar(50)
  invoiceNumber String      @map("invoice_number") @db.VarChar(50)
  clientName    String      @map("client_name") @db.VarChar(100)
  clientEmail   String      @map("client_email") @db.VarChar(255)
  date          DateTime    @db.Date
  dueDate       DateTime    @map("due_date") @db.Date
  items         Json
  subtotal      Decimal     @default(0.00) @db.Decimal(10, 2)
  taxRate       Decimal     @default(0.00) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount     Decimal     @default(0.00) @map("tax_amount") @db.Decimal(10, 2)
  discount      Decimal     @default(0.00) @db.Decimal(10, 2)
  total         Decimal     @default(0.00) @db.Decimal(10, 2)
  status        String      @default("Draft") @db.VarChar(50)
  projectId     String      @map("project_id") @db.VarChar(50)
  currency      String      @default("USD") @db.VarChar(10)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]

  @@map("invoices")
}

model PaypalSettings {
  userId   String @id @map("user_id") @db.VarChar(50)
  email    String @db.VarChar(255)
  clientId String @map("client_id") @db.VarChar(255)
  mode     String @default("sandbox") @db.VarChar(20)
  currency String @default("USD") @db.VarChar(10)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("paypal_settings")
}
